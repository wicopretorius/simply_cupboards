# Directus core
KEY=change_me_random_32_chars
SECRET=change_me_random_32_chars
PUBLIC_URL=http://localhost:8055
PORT=8055

# Admin (first bootstrap only — change password after)
ADMIN_EMAIL=cupboards@jirehsoft.com
