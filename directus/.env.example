# MySQL
DB_CLIENT=mysql
DB_HOST=127.0.0.1
# Local dev: 3307 (Docker MySQL)
# Production: 3306 (HestiaCP MySQL)
DB_PORT=3307
DB_DATABASE=simply_cupboards_db
DB_USER=cupboard_user
